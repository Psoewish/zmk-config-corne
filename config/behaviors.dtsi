#define QUICK_TAP_MS 175

// Change global core behavior preferences
&sk {
     release-after-ms = <900>;
     quick-release;
};

&sl {
     ignore-modifiers;
};

&lt {
     flavor = "balanced";
     tapping-term-ms = <200>;
     quick-tap-ms = <QUICK_TAP_MS>;
};

// Combine backspace and del by allowing shift+backspace
ZMK_BEHAVIOR(bs_morph, mod_morph,
    bindings = <&kp BSPC>, <&kp DEL>;
    mods = <(MOD_LSFT|MOD_RSFT)>;
)

// Caps word when pressed, caps lock when shift-pressed (or double tapped)
ZMK_BEHAVIOR(caps_morph, mod_morph,
     bindings = <&caps_word>, <&kp CAPS>;
     mods = <(MOD_LSFT|MOD_RSFT)>;
)

// Autoshift
#define AS(keycode) &as LS(keycode) keycode

ZMK_BEHAVIOR(as, hold_tap, 
     flavor = "tap-preferred";
     tapping-term-ms = <200>;
     quick-tap-ms = <125>;
     bindings = <&kp>, <&kp>;
)

// Layer toggle with alt+key, momentary when held
#define LTM(keycode) &ltm keycode keycode

ZMK_BEHAVIOR(ltm, mod_morph,
     bindings = <&mo>, <&tog>;
     mods = <MOD_LALT>;
)
